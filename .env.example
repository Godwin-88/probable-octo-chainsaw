# Neo4j (default: neo4j / yield-agent-dev). This stack uses host ports 7475 (Browser) and 7688 (Bolt).
# NEO4J_AUTH=neo4j/yield-agent-dev
NEO4J_PASSWORD=yield-agent-dev
# When connecting from host to this stack's Neo4j: NEO4J_URI=bolt://localhost:7688

# Redis (required for caching)
REDIS_URL=redis://localhost:6379

# Optional: RPC URLs for indexer (on-chain data)
# RPC_URL_ETHEREUM=https://eth.llamarpc.com
# RPC_URL_SEPOLIA=https://rpc.sepolia.org
# RPC_URL_POLYGON=https://polygon-rpc.com

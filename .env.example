# Neo4j (default: neo4j / yield-agent-dev). This stack uses host ports 7475 (Browser) and 7688 (Bolt).
# NEO4J_AUTH=neo4j/yield-agent-dev
NEO4J_PASSWORD=yield-agent-dev
# When connecting from host to this stack's Neo4j: NEO4J_URI=bolt://localhost:7688

# Redis (required for caching)
REDIS_URL=redis://localhost:6379

# Optional: RPC URLs for indexer and multi-chain portfolio
# RPC_URL_ETHEREUM=https://eth.llamarpc.com
# RPC_URL_SEPOLIA=https://rpc.sepolia.org
# RPC_URL_POLYGON=https://polygon-rpc.com
# RPC_URL_SOLANA=https://api.mainnet-beta.solana.com
# RPC_URL_TON=
# RPC_URL_TRON=

# OpenClaw agent chat proxy (gateway forwards POST /api/agent/chat to OpenClaw)
# OPENCLAW_GATEWAY_URL=http://localhost:18789
# OPENCLAW_TOKEN=

# TRANSACT quant platform (REQUIRED): enables quant-level financial-engineering DeFi yield strategies.
# ai-core enriches optimization with VaR/moments; MCP exposes quant_var, quant_moments, explain_formula.
# Run psychic-invention (TRANSACT) and set to its base URL (e.g. http://host.docker.internal:8000 from Docker).
TRANSACT_API_URL=http://localhost:8000

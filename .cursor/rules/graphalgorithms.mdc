### 2.3 Louvain Community Detection

**Python (python-louvain / community library):**
```python
# pip install python-louvain
import community as community_louvain
import networkx as nx

# Louvain requires undirected graph
G_undirected = G.to_undirected()
partition = community_louvain.best_partition(G_undirected, resolution=1.0)
# partition = {node_id: community_id, ...}

modularity = community_louvain.modularity(partition, G_undirected)
print(f"Modularity: {modularity:.4f}")

# Group nodes by community
from collections import defaultdict
communities = defaultdict(list)
for node, comm_id in partition.items():
    communities[comm_id].append(node)
```

**Alternative: Leiden algorithm (higher quality than Louvain):**
```python
# pip install leidenalg igraph
import igraph as ig
import leidenalg

# Convert NetworkX → igraph
edges = list(G_undirected.edges())
ig_graph = ig.Graph(edges=edges, directed=False)
partition_leiden = leidenalg.find_partition(ig_graph, leidenalg.ModularityVertexPartition)
```

**GNN equivalent — community detection via unsupervised node classification:**
```python
from torch_geometric.nn import GCNConv
from torch_geometric.utils import from_networkx

# Convert to PyG data
data = from_networkx(G_undirected)

class CommunityGNN(torch.nn.Module):
    """Unsupervised GNN: learn embeddings → cluster with K-Means."""
    def __init__(self, in_channels, hidden, embedding_dim):
        super().__init__()
        self.conv1 = GCNConv(in_channels, hidden)
        self.conv2 = GCNConv(hidden, embedding_dim)

    def forward(self, x, edge_index):
        x = F.relu(self.conv1(x, edge_index))
        return self.conv2(x, edge_index)  # node embeddings

# Then cluster embeddings
from sklearn.cluster import KMeans
model = CommunityGNN(in_channels=data.num_features, hidden=64, embedding_dim=32)
embeddings = model(data.x, data.edge_index).detach().numpy()
communities_gnn = KMeans(n_clusters=10).fit_predict(embeddings)
```


### 2.6 Node Embeddings (node2vec)

**Python (node2vec library — GDS-free):**
```python
# pip install node2vec
from node2vec import Node2Vec

# Build embeddings — equivalent to GDS node2vec
node2vec = Node2Vec(
    G,
    dimensions=128,      # embedding size
    walk_length=80,      # random walk length
    num_walks=10,        # walks per node
    p=1.0,               # return parameter
    q=0.5,               # in-out parameter (q<1 = community-focused)
    workers=4
)

model = node2vec.fit(
    window=10,
    min_count=1,
    batch_words=4
)

# Get embedding for a node
emb = model.wv[str(node_id)]

# Most similar nodes
similar = model.wv.most_similar(str(node_id), topn=5)

# Save all embeddings as numpy array
import numpy as np
node_ids = list(G.nodes())
embeddings = np.array([model.wv[str(n)] for n in node_ids])
```

**GNN equivalent (PyG node2vec):**
```python
from torch_geometric.nn import Node2Vec as PyGNode2Vec
from torch_geometric.utils import from_networkx

data = from_networkx(G)

node2vec_pyg = PyGNode2Vec(
    data.edge_index,
    embedding_dim=128,
    walk_length=20,
    context_size=10,
    walks_per_node=10,
    p=1.0,
    q=0.5,
    num_negative_samples=1,
    sparse=True
)

loader = node2vec_pyg.loader(batch_size=128, shuffle=True)
optimizer = torch.optim.SparseAdam(node2vec_pyg.parameters(), lr=0.01)

for epoch in range(100):
    node2vec_pyg.train()
    total_loss = 0
    for pos_rw, neg_rw in loader:
        optimizer.zero_grad()
        loss = node2vec_pyg.loss(pos_rw, neg_rw)
        loss.backward()
        optimizer.step()
        total_loss += loss.item()

# Final embeddings
embeddings = node2vec_pyg.embedding.weight.data.numpy()
```

